<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/bmcu_bg"
  android:fillViewport="true"
  android:scrollbars="vertical"
  android:fadeScrollbars="false"
  android:scrollbarStyle="outsideOverlay">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
      android:id="@+id/txtTitle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textSize="20sp"
      android:textStyle="bold"
      android:textColor="@color/bmcu_fg"
      android:text="BMCU Flasher (Android)"/>

    <TextView
      android:id="@+id/txtLinks"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:textSize="12sp"
      android:typeface="monospace"
      android:autoLink="web"
      android:linksClickable="true"
      android:textColor="@color/bmcu_fg"
      android:textColorLink="@color/bmcu_link"
      android:text="App: https://github.com/jarczakpawel/BMCU-Flasher&#10;Firmware: https://github.com/jarczakpawel/BMCU-C-PJARCZAK"/>

    <TextView
      android:id="@+id/txtWarnTitle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="10dp"
      android:textStyle="bold"
      android:textSize="14sp"
      android:textColor="@color/bmcu_warn"
      android:text="WARNING!"/>

    <TextView
      android:id="@+id/txtWarnText"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textSize="12sp"
      android:textColor="@color/bmcu_fg"
      android:text="Do NOT plug USB or flash while BMCU is connected to the printer."
      android:layout_marginTop="4dp"/>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:layout_marginTop="12dp">

      <TextView
        android:id="@+id/txtDeviceLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/bmcu_fg"
        android:text="USB device:"
        android:layout_marginEnd="8dp"/>

      <Spinner
        android:id="@+id/spnDevice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"/>

      <Button
        android:id="@+id/btnRefresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/bmcu_fg"
        android:background="@drawable/bmcu_button"
        android:text="Refresh"
        android:layout_marginStart="8dp"/>
    </LinearLayout>

    <TextView
      android:id="@+id/txtDeviceHint"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textColor="@color/bmcu_fg"
      android:text="Only CH340 VID=0x1A86 PID=0x7523"
      android:layout_marginTop="6dp"/>

    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:layout_marginTop="12dp"
      android:layout_marginBottom="12dp"
      android:background="@color/bmcu_divider"/>

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textColor="@color/bmcu_fg"
      android:text="Online firmware"
      android:textStyle="bold"
      android:textSize="16sp"/>

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textColor="@color/bmcu_fg"
      android:text="Filament load force:"
      android:layout_marginTop="10dp"/>

    <Spinner
      android:id="@+id/spnForce"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"/>

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textColor="@color/bmcu_fg"
      android:text="BMCU slot:"
      android:layout_marginTop="10dp"/>

    <Spinner
      android:id="@+id/spnSlot"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"/>

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textColor="@color/bmcu_fg"
      android:text="Retraction:"
      android:layout_marginTop="10dp"/>

    <Spinner
      android:id="@+id/spnRetract"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"/>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:layout_marginTop="10dp">

      <CheckBox
        android:id="@+id/chkAutoload"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/bmcu_fg"
        android:text="Autoload"
        android:checked="true"/>

      <CheckBox
        android:id="@+id/chkRgb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/bmcu_fg"
        android:text="RGB LED (filament color)"
        android:layout_marginStart="16dp"
        android:checked="true"/>
    </LinearLayout>

    <CheckBox
      android:id="@+id/chkNoFast"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textColor="@color/bmcu_fg"
      android:text="No fast (compatibility)"
      android:checked="false"
      android:layout_marginTop="6dp"/>

    <Button
      android:id="@+id/btnFlash"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textColor="@color/bmcu_fg"
      android:background="@drawable/bmcu_button"
      android:text="Flash"
      android:layout_marginTop="14dp"/>

    <ProgressBar
      android:id="@+id/pbar"
      style="?android:attr/progressBarStyleHorizontal"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="10dp"
      android:max="100"
      android:progress="0"/>

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textColor="@color/bmcu_fg"
      android:text="Log"
      android:textStyle="bold"
      android:layout_marginTop="12dp"/>

    <TextView
      android:id="@+id/txtLog"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:background="@drawable/bmcu_panel"
      android:padding="8dp"
      android:textSize="12sp"
      android:typeface="monospace"
      android:textColor="@color/bmcu_fg"/>

  </LinearLayout>
</ScrollView>
